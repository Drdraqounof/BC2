generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}
////////////////////////////////
// ENUMS
///////////////////////////////

enum CampaignStatus {
  DRAFT
  IN_PROGRESS
  NEEDS_FOLLOW_UP
  ON_TRACK
  COMPLETED
}

enum CampaignType {
  MISSING_ASSIGNMENTS_RECOVERY
  ATTENDANCE_IMPROVEMENT
  TEST_PREPARATION_INITIATIVE
  STUDENT_PERFORMANCE_BOOST
  PARENT_ENGAGEMENT_PUSH
  CUSTOM
}

enum CampaignStudentStatus {
  PENDING
  NEEDS_REMINDER
  FAMILY_OUTREACH
  INTERVENTION_ADDED
  IMPROVING
  COMPLETED
}

enum SignalType {
  MISSING_WORK
  ATTENDANCE
  ASSESSMENT_RISK
  ENGAGEMENT
  BEHAVIOR
  OTHER
}

enum SignalSeverity {
  LOW
  MEDIUM
  HIGH
}

enum PromptCategory {
  FAMILY_OUTREACH
  STUDENT_CHECK_IN
  COACHING_SUMMARY
  ADMIN_UPDATE
  CUSTOM
}

enum TaskPriority {
  LOW
  MEDIUM
  HIGH
}

enum ActivityType {
  CAMPAIGN_CREATED
  CAMPAIGN_STATUS_CHANGED
  STUDENT_ADDED_TO_CAMPAIGN
  STUDENT_STATUS_CHANGED
  TASK_CREATED
  TASK_ASSIGNED
  TASK_COMPLETED
  NOTE_ADDED
  SIGNAL_DETECTED
  SIGNAL_RESOLVED
  OTHER
}

model School {
  id        String    @id @default(cuid())
  name      String    @unique
  teachers  Teacher[]
  students  Student[]
  createdAt DateTime  @default(now())
  updatedAt DateTime  @updatedAt

  @@index([name])
}

model Teacher {
  id            String         @id @default(cuid())
  email         String         @unique
  firstName     String
  lastName      String
  schoolId      String?
  school        School?        @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  campaigns     Campaign[]     @relation("CampaignOwner")
  authoredNotes CampaignNote[] @relation("CampaignNoteAuthor")
  createdTasks  Task[]         @relation("TaskCreator")
  activityLogs  ActivityLog[]  @relation("ActivityCreator")
  createdAt     DateTime       @default(now())
  updatedAt     DateTime       @updatedAt

  @@index([schoolId, email])
}

model Student {
  id            String            @id @default(cuid())
  externalId    String?           @unique
  firstName     String
  lastName      String
  gradeLabel    String?
  courseLabel   String?
  supportStatus String?
  schoolId      String?
  school        School?           @relation(fields: [schoolId], references: [id], onDelete: SetNull)
  campaigns     CampaignStudent[]
  taskAssignments TaskAssignment[]
  signals       StudentSignal[]
  createdAt     DateTime          @default(now())
  updatedAt     DateTime          @updatedAt

  @@index([schoolId])
  @@index([lastName, firstName])
}

model Campaign {
  id                    String            @id @default(cuid())
  title                 String
  description           String?
  type                  CampaignType      @default(CUSTOM)
  customType            String?           // For schools to add custom campaign types
  goal                  String
  status                CampaignStatus    @default(DRAFT)
  progressSnapshot      Int               @default(0) // Computed from student statuses and task completion - not source of truth
  startDate             DateTime?
  endDate               DateTime?
  ownerId               String
  owner                 Teacher           @relation("CampaignOwner", fields: [ownerId], references: [id])
  studentLinks          CampaignStudent[]
  notes                 CampaignNote[]
  tasks                 Task[]
  promptTemplates       PromptTemplate[]
  activityLogs          ActivityLog[]     @relation("CampaignActivity")
  createdAt             DateTime          @default(now())
  updatedAt             DateTime          @updatedAt

  @@index([ownerId, status])
  @@index([type, status])
}

model CampaignStudent {
  id              String                @id @default(cuid())
  campaignId      String
  studentId       String
  status          CampaignStudentStatus @default(PENDING)
  customStatus    String?               // For schools to add custom statuses
  note            String?
  campaign        Campaign              @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  student         Student               @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activityLogs    ActivityLog[]         @relation("CampaignStudentActivity")
  createdAt       DateTime              @default(now())
  updatedAt       DateTime              @updatedAt

  @@unique([campaignId, studentId])
  @@index([studentId, status])
}

model StudentSignal {
  id             String         @id @default(cuid())
  studentId      String
  type           SignalType
  customType     String?        // For schools to add custom signal types
  label          String
  severity       SignalSeverity @default(MEDIUM)
  isActive       Boolean        @default(true)
  followUpStatus String?
  detectedAt     DateTime       @default(now())
  resolvedAt     DateTime?
  student        Student        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  activityLogs   ActivityLog[]  @relation("SignalActivity")

  @@index([studentId, isActive])
  @@index([type, severity])
}

model CampaignNote {
  id         String    @id @default(cuid())
  campaignId String
  authorId   String?
  body       String
  campaign   Campaign  @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  author     Teacher?  @relation("CampaignNoteAuthor", fields: [authorId], references: [id], onDelete: SetNull)
  createdAt  DateTime  @default(now())
  updatedAt  DateTime  @updatedAt

  @@index([campaignId, createdAt])
}

model PromptTemplate {
  id         String         @id @default(cuid())
  title      String
  prompt     String
  category   PromptCategory @default(CUSTOM)
  isSystem   Boolean        @default(false)
  campaignId String?
  campaign   Campaign?      @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  createdAt  DateTime       @default(now())
  updatedAt  DateTime       @updatedAt

  @@index([category, isSystem])
}

model Task {
  id                String             @id @default(cuid())
  title             String
  description       String?
  dueDate           DateTime?
  priority          TaskPriority       @default(MEDIUM)
  rubric            String?
  attachmentLinks   String?
  campaignId        String?
  creatorId         String
  campaign          Campaign?          @relation(fields: [campaignId], references: [id], onDelete: SetNull)
  creator           Teacher            @relation("TaskCreator", fields: [creatorId], references: [id], onDelete: Cascade)
  taskAssignments   TaskAssignment[]
  createdAt         DateTime           @default(now())
  updatedAt         DateTime           @updatedAt

  @@index([campaignId])
  @@index([creatorId, createdAt])
  @@index([dueDate])
}

model TaskAssignment {
  id          String    @id @default(cuid())
  taskId      String
  studentId   String
  completedAt DateTime?
  grade       String?
  task        Task      @relation(fields: [taskId], references: [id], onDelete: Cascade)
  student     Student   @relation(fields: [studentId], references: [id], onDelete: Cascade)
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt

  @@unique([taskId, studentId])
  @@index([studentId, completedAt])
}

model ActivityLog {
  id                   String         @id @default(cuid())
  type                 ActivityType
  description          String
  campaignId           String?
  campaign             Campaign?      @relation("CampaignActivity", fields: [campaignId], references: [id], onDelete: Cascade)
  campaignStudentId    String?
  campaignStudent      CampaignStudent? @relation("CampaignStudentActivity", fields: [campaignStudentId], references: [id], onDelete: Cascade)
  studentSignalId      String?
  studentSignal        StudentSignal? @relation("SignalActivity", fields: [studentSignalId], references: [id], onDelete: Cascade)
  createdBy            String?
  creator              Teacher?       @relation("ActivityCreator", fields: [createdBy], references: [id], onDelete: SetNull)
  metadata             String?        // JSON field for additional context
  createdAt            DateTime       @default(now())

  @@index([campaignId, createdAt])
  @@index([type, createdAt])
  @@index([createdBy])
}
